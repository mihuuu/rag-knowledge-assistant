# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_your_langsmith_api_key
LANGSMITH_PROJECT=rag-knowledge-assistant

# Model routing — use "provider/model" format (e.g. "anthropic/claude-sonnet-4-6", "openai/gpt-4o")
# Plain names default to OpenAI. If not set, falls back to LLM_MODEL.
# CONDENSE_MODEL=openai/gpt-4o-mini
# GENERATION_MODEL=anthropic/claude-haiku-4-5
# EVAL_MODEL=openai/gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# LLM_MODEL=gpt-4o-mini

# Cohere (for reranking)
# COHERE_API_KEY=your-cohere-api-key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ragagent

# Redis
REDIS_URL=redis://redis:6379

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATA_DIR=/app/data

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
